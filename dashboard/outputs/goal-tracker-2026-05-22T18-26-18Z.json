    "source-logs": {
      "type": "Text",
      "props": {
        "text": "logs = ok",
        "variant": "caption"
      }
    },
    "source-git": {
      "type": "Text",
      "props": {
        "text": "git = ok",
        "variant": "caption"
      }
    },
    "source-gh-pr": {
      "type": "Text",
      "props": {
        "text": "gh_pr = ok",
        "variant": "caption"
      }
    },
    "source-gh-issue": {
      "type": "Text",
      "props": {
        "text": "gh_issue = ok",
        "variant": "caption"
      }
    },
    "source-cron": {
      "type": "Text",
      "props": {
        "text": "cron-state = ok",
        "variant": "caption"
      }
    }
  }
}
